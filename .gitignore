*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.venv/
venv/

# Native/CMake build products
build*/
cmake-build-*/
_skbuild/
CMakeCache.txt
CMakeFiles/
CTestTestfile.cmake
