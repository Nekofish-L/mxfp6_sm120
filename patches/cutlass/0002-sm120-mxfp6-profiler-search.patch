+// A fixed-shape SM120 GEMM can use the same arithmetic tile traversal as
+// SM100 without issuing CLC fetches. StaticPersistentTileScheduler100 exposes
+// the scheduler interface consumed by the SM120 universal kernel and is useful
+// for profiler-driven fixed-shape inference dispatch.
+template <
+  class TileShape,
+  class ClusterShape,
+  uint32_t SchedulerPipelineStageCount
+>
+struct TileSchedulerSelector<
+    StaticPersistentScheduler,
+    arch::Sm120,
+    TileShape,
+    ClusterShape,
+    SchedulerPipelineStageCount> {
+  using Scheduler = StaticPersistentTileScheduler100;
+};
+
 
